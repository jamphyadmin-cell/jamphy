generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                   String            @id @default(cuid())
  name                 String?
  email                String?           @unique
  emailVerified        DateTime?
  image                String?
  college              String?
  course               String?
  dob                  String?
  username             String?           @unique
  year                 String?
  showActivityPublicly Boolean           @default(true)
  showHeatmapPublicly  Boolean           @default(true)
  showStatsPublicly    Boolean           @default(true)
  showStreakPublicly   Boolean           @default(true)
  showSubjectsPublicly Boolean           @default(true)
  accounts             Account[]
  attempts             Attempt[]
  comments             Comment[]
  dailyGoals           DailyGoal[]
  following            Follow[]          @relation("Following")
  followers            Follow[]          @relation("Followers")
  hostedRooms          LiveRoom[]        @relation("RoomHost")
  notifications        Notification[]
  reports              Report[]
  receivedInvites      RoomInvite[]      @relation("InviteReceiver")
  sentInvites          RoomInvite[]      @relation("InviteSender")
  roomParticipations   RoomParticipant[]
  sessions             Session[]
  UserScore            UserScore?
  vaultItems           Vault[]
  studyPlan            StudyPlan?
  posts                Post[]

  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Report {
  id          String   @id @default(cuid())
  questionId  String
  description String
  createdAt   DateTime @default(now())
  userId      String?
  status      String   @default("PENDING")
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Vault {
  id              String   @id @default(cuid())
  userId          String
  questionId      String
  reviewInterval  Int      @default(1)
  nextReviewDate  DateTime @default(now())
  lastAttemptedAt DateTime @default(now())
  totalAttempts   Int      @default(0)
  correctStreak   Int      @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextReviewDate])
}

model DailyGoal {
  id              String   @id @default(cuid())
  userId          String
  targetQuestions Int      @default(20)
  date            DateTime @db.Date
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Attempt {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  subject        String   @default("")
  selectedAnswer String
  isCorrect      Boolean
  timeTaken      Int
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isCorrect])
}

model Question {
  id             String   @id @default(cuid())
  year           String
  subject        String
  type           String
  question       String
  options        String[]
  correctAnswer  Int?
  correctAnswers Int[]
  natAnswer      String?
  hasImage       Boolean  @default(false)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  imageUrl       String?
  solution       String?
  optionImages   String[]
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Comment {
  id         String   @id @default(cuid())
  text       String
  questionId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
}

model LiveRoom {
  id           String            @id @default(cuid())
  hostId       String
  status       String            @default("LOBBY")
  config       Json
  questions    Json
  createdAt    DateTime          @default(now())
  host         User              @relation("RoomHost", fields: [hostId], references: [id])
  invites      RoomInvite[]
  participants RoomParticipant[]
}

model RoomParticipant {
  id         String   @id @default(cuid())
  roomId     String
  userId     String
  progress   Int      @default(0)
  score      Int      @default(0)
  isFinished Boolean  @default(false)
  joinedAt   DateTime @default(now())
  room       LiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model RoomInvite {
  id         String   @id @default(cuid())
  roomId     String
  senderId   String
  receiverId String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  receiver   User     @relation("InviteReceiver", fields: [receiverId], references: [id])
  room       LiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender     User     @relation("InviteSender", fields: [senderId], references: [id])

  @@index([roomId])
  @@index([receiverId])
  @@index([senderId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserScore {
  id                 String   @id
  userId             String   @unique
  totalPoints        Int      @default(0)
  weeklyPoints       Int      @default(0)
  allTimePoints      Int      @default(0)
  questionsAttempted Int      @default(0)
  correctAnswers     Int      @default(0)
  currentLeague      String   @default("Bronze")
  updatedAt          DateTime
  User               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyPlan {
  id            String      @id @default(cuid())
  userId        String      @unique
  examDate      DateTime
  hoursPerDay   Int
  targetRank    String
  preferences   String      @default("")
  generatedPlan Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks         StudyTask[]
}

model StudyTask {
  id             String    @id @default(cuid())
  planId         String
  weekNumber     Int
  day            Int
  topic          String
  questionTarget Int
  estimatedTime  Int       @default(0) // minutes
  completed      Boolean   @default(false)
  completedAt    DateTime?

  plan           StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  @@index([planId, weekNumber, day])
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String
  authorId    String
  status      String   @default("PENDING") // DRAFT, PENDING, PUBLISHED
  coverImage  String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
  views       Int      @default(0)

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([status])
}
