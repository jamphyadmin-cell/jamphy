generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  dob           String?
  college       String?
  year          String?
  course        String?
  accounts      Account[]
  sessions      Session[]
  reports             Report[]
  hostedRooms         LiveRoom[]        @relation("RoomHost")
  roomParticipations  RoomParticipant[]
  sentInvites         RoomInvite[]      @relation("InviteSender")
  receivedInvites     RoomInvite[]      @relation("InviteReceiver")
  vaultItems          Vault[]
  dailyGoals          DailyGoal[]
  attempts            Attempt[]
  userScore           UserScore?
  followers           Follow[]          @relation("Followers")
  following           Follow[]          @relation("Following")
  comments            Comment[]
  notifications       Notification[]
  showStreakPublicly    Boolean   @default(true)
  showStatsPublicly     Boolean   @default(true)
  showHeatmapPublicly   Boolean   @default(true)
  showActivityPublicly  Boolean   @default(true)
  showSubjectsPublicly  Boolean   @default(true)

  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Report {
  id          String   @id @default(cuid())
  questionId  String
  description String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Vault {
  id              String   @id @default(cuid())
  userId          String
  questionId      String
  reviewInterval  Int      @default(1)
  nextReviewDate  DateTime @default(now())
  lastAttemptedAt DateTime @default(now())
  totalAttempts   Int      @default(0)
  correctStreak   Int      @default(0)
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, questionId])
  @@index([userId, nextReviewDate])
}

model DailyGoal {
  id              String   @id @default(cuid())
  userId          String
  targetQuestions Int      @default(20)
  date            DateTime @db.Date
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
  @@index([userId, date])
}

model Attempt {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  subject        String   @default("")
  selectedAnswer String
  isCorrect      Boolean
  timeTaken      Int      // seconds
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([userId, isCorrect])
}

model Question {
  id             String   @id @default(cuid())
  year           String
  subject        String
  type           String   // MCQ, MSQ, NAT
  question       String   @db.Text
  options        String[] // Array of strings, null/empty for NAT
  correctAnswer  Int?     // For MCQ
  correctAnswers Int[]    // For MSQ
  natAnswer      String?  // For NAT
  hasImage       Boolean  @default(false)
  imageUrl       String?
  solution       String?  @db.Text
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UserScore {
  id                 String   @id @default(cuid())
  userId             String   @unique
  totalPoints        Int      @default(0)
  weeklyPoints       Int      @default(0)
  allTimePoints      Int      @default(0)
  questionsAttempted Int      @default(0)
  correctAnswers     Int      @default(0)
  currentLeague      String   @default("Bronze")
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Comment {
  id          String   @id @default(cuid())
  text        String   @db.Text
  questionId  String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([userId])
}

model LiveRoom {
  id          String   @id @default(cuid())
  hostId      String
  host        User     @relation("RoomHost", fields: [hostId], references: [id])
  status      String   @default("LOBBY") // LOBBY, ACTIVE, FINISHED
  config      Json
  questions   Json
  createdAt   DateTime @default(now())
  
  participants RoomParticipant[]
  invites      RoomInvite[]
}

model RoomParticipant {
  id          String   @id @default(cuid())
  roomId      String
  room        LiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress    Int      @default(0)
  score       Int      @default(0)
  isFinished  Boolean  @default(false)
  joinedAt    DateTime @default(now())

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model RoomInvite {
  id          String   @id @default(cuid())
  roomId      String
  room        LiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation("InviteSender", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("InviteReceiver", fields: [receiverId], references: [id])
  status      String   @default("PENDING") // PENDING, ACCEPTED, DECLINED
  createdAt   DateTime @default(now())

  @@index([roomId])
  @@index([receiverId])
  @@index([senderId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "WARNING" | "INFO"
  message     String   @db.Text
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}
